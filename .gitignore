# =====================================================
# Book Review System Backend - .gitignore
# =====================================================

# Compiled class files
*.class

# Log files
*.log
logs/
*.log.*

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# Virtual machine crash logs
hs_err_pid*
replay_pid*

# =====================================================
# Gradle
# =====================================================
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
!**/src/main/**/build/
!**/src/test/**/build/

# =====================================================
# IntelliJ IDEA
# =====================================================
.idea/
*.iws
*.iml
*.ipr
out/
!**/src/main/**/out/
!**/src/test/**/out/

# =====================================================
# Eclipse
# =====================================================
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache
bin/
!**/src/main/**/bin/
!**/src/test/**/bin/

# =====================================================
# NetBeans
# =====================================================
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# =====================================================
# VS Code
# =====================================================
.vscode/
*.code-workspace

# =====================================================
# Spring Boot
# =====================================================
*.pid
*.pid.lock
application-*.yml
!application.yml
!application-dev.yml
!application-test.yml

# =====================================================
# Database
# =====================================================
*.db
*.sqlite
*.sqlite3
# database-setup.sql is intentionally tracked for documentation

# =====================================================
# OS Generated Files
# =====================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# =====================================================
# Temporary Files
# =====================================================
*.tmp
*.temp
*.swp
*.swo
*~

# =====================================================
# Test Reports
# =====================================================
build/reports/
test-results/
coverage/

# =====================================================
# Environment Variables
# =====================================================
.env
.env.local
.env.development
.env.test
.env.production

# =====================================================
# Application Specific
# =====================================================
# Keep database setup script for reference but exclude actual database files
# database-setup.sql is included for documentation purposes

# =====================================================
# Logs and Monitoring
# =====================================================
logs/
*.log
*.log.*
prometheus/
metrics/

# =====================================================
# Cache and Temporary
# =====================================================
.cache/
.temp/
tmp/
temp/
